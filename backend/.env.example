##############################################################
# Information Environment Variables
##############################################################
PROJECT_NAME="FastAPI Async SQLModel Boilerplate"
PROJECT_DESCRIPTION="A fully asynchronous FastAPI boilerplate. Built for extensibility and speed, it incorporates FastAPI, SQLModel, Alembic, PostgreSQL, Redis, Celery and Locust. 🚀"
APP_VERSION="0.0.1"
CONTACT_NAME="Example Name"
CONTACT_EMAIL="example@example.com.br"
LICENSE_NAME="MIT"

##############################################################
# Web Server Environment Variables
##############################################################
API_BASE_URL="http://localhost:8000"
WEB_CONCURRENCY=1

##############################################################
# Security Environment Variables
##############################################################
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

##############################################################
# Email Environment Variables
##############################################################
SMTP_HOST="smtp.azurecomm.net"
SMTP_PORT=587
SMTP_USER="SMTP_USER"
SMTP_PASSWORD="SMTP_PASSWORD"
EMAILS_FROM_EMAIL="email@example.com"
EMAILS_FROM_NAME="Example Name"
EMAIL_SENDER="logger"

##############################################################
# Database Environment Variables
##############################################################
POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_SERVER=""
POSTGRES_PORT=5432
POSTGRES_DB=""
POSTGRES_POOL_SIZE=100

##############################################################
# Redis for Caching Environment Variables
##############################################################
REDIS_CACHE_HOST=""
REDIS_CACHE_PORT=6379
REDIS_CACHE_DB=0
REDIS_CACHE_USERNAME="default"
REDIS_CACHE_PASSWORD=""
REDIS_CACHE_USE_SSL=False

##############################################################
# Redis for Rate Limit Environment Variables (Optional)
##############################################################
REDIS_RATE_LIMIT_HOST=""
REDIS_RATE_LIMIT_PORT=6379
REDIS_RATE_LIMIT_DB=0
REDIS_RATE_LIMIT_USERNAME="default"
REDIS_RATE_LIMIT_PASSWORD=""
REDIS_RATE_LIMIT_USE_SSL=False

##############################################################
# Redis for Tasks Queue Environment Variables (Optional)
##############################################################
REDIS_QUEUE_HOST=""
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_DB=0
REDIS_QUEUE_USERNAME="default"
REDIS_QUEUE_PASSWORD=""
REDIS_QUEUE_USE_SSL=False

##############################################################
# First Admin User Creation Environment Variables
##############################################################
USER_FIRST_ADMIN_NAME=""
USER_FIRST_ADMIN_EMAIL=""
USER_FIRST_ADMIN_USERNAME=""
USER_FIRST_ADMIN_PASSWORD=""

##############################################################
# Running Mode Environment Variables
##############################################################
ENVIRONMENT="local"

##############################################################
# Rate Limit Environment Variables
##############################################################
DEFAULT_RATE_LIMIT_LIMIT=4
DEFAULT_RATE_LIMIT_PERIOD=1
